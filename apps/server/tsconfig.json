{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "types": ["node", "bun"],
    "lib": ["ES2023", "esnext.disposable"],
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@studio/contracts": ["../../packages/contracts/src/index.ts"],
      "@studio/shared/*": ["../../packages/shared/src/*"]
    },
    "plugins": [
      {
        "name": "@effect/language-service",
        "namespaceImportPackages": ["@effect/platform-node"],
        "diagnosticSeverity": {
          "importFromBarrel": "error",
          "anyUnknownInErrorContext": "warning",
          "instanceOfSchema": "warning",
          "deterministicKeys": "off",
          "preferSchemaOverJson": "off",
          "globalErrorInEffectFailure": "off"
        }
      }
    ]
  },
  "include": [
    "src",
    "tsdown.config.ts",
    "scripts",
    "integration",
    "../../scripts/lib",
    "../../packages/shared/src",
    "../../packages/contracts/src"
  ],
  "exclude": ["src/**/*.test.ts", "integration/**/*.test.ts"]
}
